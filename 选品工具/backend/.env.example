REDDIT_USER_AGENT=RADAR-AI/1.0

APIFY_API_TOKEN=

# ── Notifications ─────────────────────────────
FEISHU_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ── Deployment ────────────────────────────────
FRONTEND_URL=http://localhost:5173
