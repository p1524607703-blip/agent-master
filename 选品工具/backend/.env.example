# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/radar_ai"

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── App ───────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here

# ── AI ────────────────────────────────────────
MINIMAX_API_KEY=

# ── Data Sources ──────────────────────────────
REDDIT_CLIENT_ID=
